  "tokenColors": [
    {
      "name": "comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8f8f8f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#299799"
      }
    },
    {
      "name": "string",
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#8374d8"
      }
    },
    {
      "name": "number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#3878c7"
      }
    },
    {
      "name": "constant",
      "scope": [
        "constant.language",
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#3878c7"
      }
    },
    {
      "name": "function",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#299799"
      }
    },
    {
      "name": "parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameter"
      ],
      "settings": {
        "foreground": "#3678c9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#3678c9"
      }
    },
    {
      "name": "interface",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.type-parameter"
      ],
      "settings": {
        "foreground": "#3678c9"
      }
    },
    {
      "name": "namespace",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#3c6daa"
      }
    },
    {
      "name": "variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#b8b8b8"
      }
    },
    {
      "name": "operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#299799"
      }
    },
    {
      "name": "punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#b8b8b8"
      }
    },
    {
      "name": "tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#299799"
      }
    },
    {
      "name": "attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#3678c9"
      }
    },
    {
      "name": "decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#3c6daa",
        "fontStyle": "italic"
      }
    },
    {
      "name": "regex",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "keyword.other.regex"
      ],
      "settings": {
        "foreground": "#3c6daa"
      }
    },
    {
      "name": "invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#43c4c7"
      }
    },
    {
      "name": "deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#3878c7"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#3c6daa",
    "class": "#3678c9",
    "enum": "#3878c7",
    "interface": "#3678c9",
    "struct": "#3678c9",
    "type": "#3678c9",
    "typeParameter": "#3c6daa",
    "parameter": "#3678c9",
    "variable": "#ffffff",
    "variable.readonly": "#3878c7",
    "property": "#b8b8b8",
    "property.readonly": "#3878c7",
    "enumMember": "#3878c7",
    "event": "#3c6daa",
    "function": "#299799",
    "method": "#299799",
    "macro": "#43c4c7",
    "keyword": "#299799",
    "comment": "#8f8f8f",
    "string": "#8374d8",
    "number": "#3878c7",
    "regexp": "#3c6daa",
    "operator": "#299799",
    "decorator": "#3c6daa",
    "*.declaration": "#ffffff",
    "*.static": "#3c6daa",
    "*.defaultLibrary": "#8f8f8f",
    "*.deprecated": "#3878c7"
  }
}